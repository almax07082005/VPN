# Secrets — never commit. The operator creates russia/.env to feed the
# exit-handoff values into docker compose; after first boot it can be deleted
# (state lives in the named volume instead).
.env
**/.env

# Belt-and-suspenders: deployment-info.txt is written inside the container
# volume, but operators occasionally `docker cp` it to the host for safekeeping.
**/deployment-info.txt

# OS / editor cruft
.DS_Store
*.swp
.idea/
.vscode/
