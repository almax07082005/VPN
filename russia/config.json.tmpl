{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "servers": [
      { "tag": "dns_ru",     "address": "77.88.8.8",                 "detour": "direct"        },
      { "tag": "dns_remote", "address": "https://1.1.1.1/dns-query", "detour": "to-exit" }
    ],
    "rules": [
      { "rule_set": ["geosite-category-ru"], "server": "dns_ru" }
    ],
    "final": "dns_remote",
    "strategy": "prefer_ipv4",
    "independent_cache": true
  },
  "inbounds": [
    {
      "type": "vless",
      "tag": "vless-in",
      "listen": "::",
      "listen_port": 443,
      "users": ${RU_USERS_JSON},
      "tls": {
        "enabled": true,
        "server_name": "www.microsoft.com",
        "reality": {
          "enabled": true,
          "handshake": {
            "server": "www.microsoft.com",
            "server_port": 443
          },
          "private_key": "${RU_REALITY_PRIVKEY}",
          "short_id": ["${RU_SHORT_ID}"]
        }
      },
      "sniff": true,
      "sniff_override_destination": false
    }
  ],
  "outbounds": [
    { "type": "direct", "tag": "direct" },
    {
      "type": "vless",
      "tag": "to-exit",
      "server": "${EXIT_SERVER_IP}",
      "server_port": 443,
      "uuid": "${EXIT_USER_UUID}",
      "flow": "xtls-rprx-vision",
      "tls": {
        "enabled": true,
        "server_name": "www.microsoft.com",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "reality": {
          "enabled": true,
          "public_key": "${EXIT_REALITY_PUBKEY}",
          "short_id": "${EXIT_SHORT_ID}"
        }
      }
    },
    { "type": "block", "tag": "block"   },
    { "type": "dns",   "tag": "dns-out" }
  ],
  "route": {
    "rule_set": [
      {
        "type": "remote",
        "tag": "geosite-category-ru",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-ru.srs",
        "download_detour": "to-exit",
        "update_interval": "24h0m0s"
      }
    ],
    "rules": [
      { "protocol": "dns",     "outbound": "dns-out" },
      { "ip_is_private": true, "outbound": "direct"  },
      { "rule_set": ["geosite-category-ru"], "outbound": "direct" }
    ],
    "final": "to-exit",
    "auto_detect_interface": true
  }
}
