# Telegram Bot API token for the public bot (the one users /start to join).
# From @BotFather.
BOT_TOKEN=123456:replace-me

# Telegram Bot API token for the admin bot (only the admin chats with this).
# Create a separate bot in @BotFather and put its token here.
ADMIN_BOT_TOKEN=123456:replace-me

# Telegram numeric user id of the single admin (get yours from @userinfobot).
# Used to gate the admin bot — anyone else messaging it is ignored.
ADMIN_TG_ID=000000000

# Strong random password for the local Postgres (e.g. `openssl rand -base64 24`)
POSTGRES_PASSWORD=replace-me
